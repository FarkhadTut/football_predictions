# Copy to .env (never commit) and fill in values.

# the-odds-api.com — free tier: 500 req/month
THE_ODDS_API_KEY=

# SQLite location (relative to apps/predictor)
PREDICTOR_DB_URL=sqlite:///./data/predictor.db

# Where terminal-Claude qualitative notes get written
PREDICTOR_NOTES_DIR=./data/notes

# Log level for structlog
PREDICTOR_LOG_LEVEL=INFO
